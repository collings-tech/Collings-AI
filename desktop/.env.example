# -------------------------------------------------------
# Collings AI Desktop — Environment Variables
# Copy this file to .env and fill in your values.
# -------------------------------------------------------

# URL of your backend API server
VITE_BACKEND_URL=http://localhost:5000/v1

# Your Anthropic API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Your local timezone (used for scheduling posts)
# Examples: America/New_York, Europe/London, Asia/Manila, Australia/Sydney
USER_TIMEZONE=America/New_York
