{
  "name": "collings-ai-desktop",
  "version": "1.1.0",
  "description": "Collings AI Desktop App",
  "author": {
    "name": "Collings AI",
    "email": "support@collings.ai"
  },
  "main": "main/index.js",
  "scripts": {
    "start": "concurrently --kill-others-on-fail \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "make": "electron-forge make",
    "build": "vite build && electron-forge make",
    "dist": "vite build && ./node_modules/.bin/electron-builder && node scripts/stamp-icon.js"
  },
  "build": {
    "appId": "com.collings.ai",
    "productName": "Collings AI",
    "publish": {
      "provider": "github",
      "owner": "Walls2002",
      "repo": "Collings-AI"
    },
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "dist/**/*",
      "main/**/*",
      "assets/**/*",
      "renderer/public/**/*",
      "node_modules/**/*",
      "package.json",
      ".env"
    ],
    "extraResources": [],
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/images/collings-logo.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Collings AI",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "axios": "^1.6.0",
    "dotenv": "^16.4.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "node-cron": "^3.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^2.15.4",
    "winston": "^3.13.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "wait-on": "^7.2.0"
  }
}
