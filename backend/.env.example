PORT=5000
MONGODB_URI=mongodb+srv://...
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
AES_ENCRYPTION_KEY=your_32_char_aes_key_here_12345
ANTHROPIC_API_KEY=sk-ant-...
MAX_JOBS_PER_CYCLE=10
SEO_REWRITE_THRESHOLD=40

# SMTP Email via Brevo (for OTP verification)
# Credentials: Brevo dashboard → Transactional → SMTP & API → SMTP tab
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login_email@example.com
SMTP_PASS=your_brevo_smtp_key
SMTP_FROM=Collings AI <your_brevo_login_email@example.com>
